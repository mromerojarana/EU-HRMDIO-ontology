        <untitled-ontology-4:is_reusable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</untitled-ontology-4:is_reusable>
        <untitled-ontology-4:udi_di>(01)00800002222291</untitled-ontology-4:udi_di>
        <rdfs:comment xml:lang="en">Instance representing the Portico Transcatheter Heart Valve (THV), a Class III implantable medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">DEV-003 Portico THV</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DevicePerformance_Inst -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DevicePerformance_Inst">
        <rdf:type rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DevicePerformance"/>
        <rdfs:comment xml:lang="en">Instance representing a risk related to device performance issues, such as malfunction or reduced effectiveness.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Performance Risk</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA-003 -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA-003">
        <rdf:type rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA"/>
        <untitled-ontology-4:correctsIncident rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#INC-003"/>
        <untitled-ontology-4:hasActionType rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#InSituCorrection_Inst"/>
        <untitled-ontology-4:action_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-03-15T00:00:00</untitled-ontology-4:action_date>
        <untitled-ontology-4:closure_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-06-30T00:00:00</untitled-ontology-4:closure_date>
        <untitled-ontology-4:countries_affected>EU-wide</untitled-ontology-4:countries_affected>
        <untitled-ontology-4:devices_affected rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">320</untitled-ontology-4:devices_affected>
        <untitled-ontology-4:eudamed_fsca_ref>EU-FSCA-2024-000003</untitled-ontology-4:eudamed_fsca_ref>
        <untitled-ontology-4:fsca_description>Enhanced deployment training and updated IFU for Portico valve implantation technique. New implantation checklist mandatory for all TAVI centres.</untitled-ontology-4:fsca_description>
        <untitled-ontology-4:fsca_status>Closed</untitled-ontology-4:fsca_status>
        <untitled-ontology-4:scope>Portico THV sizes 23mm and 25mm from lots before 2023-11</untitled-ontology-4:scope>
        <rdfs:comment xml:lang="en">Field Safety Corrective Action associated with the Portico THV device, involving corrective measures following reported incidents.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA-003 Portico Valve Recall</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Germany -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Germany">
