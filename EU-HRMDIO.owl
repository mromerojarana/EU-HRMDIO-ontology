        <rdfs:label xml:lang="en">Class III</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DEV-003 -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DEV-003">
        <rdf:type rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Device"/>
        <untitled-ontology-4:hasDeviceType rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ImplantableDevice_Inst"/>
