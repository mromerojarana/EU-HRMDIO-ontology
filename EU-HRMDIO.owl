    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#INC-003 -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#INC-003">
