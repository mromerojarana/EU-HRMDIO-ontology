<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4/"
     xml:base="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:untitled-ontology-4="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4">
        <dc:creator xml:lang="en">Manuel Romero Jarana</dc:creator>
        <dc:title xml:lang="en">An ontology for representing high-risk medical devices and in vitro diagnostic devices regulated in the European Union, including their manufacturers, incidents, risks, corrective actions, and regulatory frameworks.</dc:title>
        <dc:title xml:lang="en">EU-HRMDIO (European High-Risk Medical Device &amp; IVD Ontology)</dc:title>
        <rdfs:comment xml:lang="en">EU-HRMDIO is an ontology designed to model the domain of high-risk medical devices and in vitro diagnostic devices within the European regulatory context (MDR and IVDR). It integrates devices, incidents, risks, FSCAs, manufacturers, and regulatory frameworks, enabling semantic interoperability and linked data publication.</rdfs:comment>
        <owl:versionInfo xml:lang="en">Version 1.0 – April 2026</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#sameAs -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#sameAs"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#affectsCountry -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#affectsCountry">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Country"/>
        <rdfs:comment xml:lang="en">Relates an FSCA to the country that is affected by it.</rdfs:comment>
        <rdfs:label xml:lang="en">Affects Country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#affectsDevice -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#affectsDevice">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Device"/>
        <rdfs:comment xml:lang="en">Links an incident to the device that is impacted by it.</rdfs:comment>
        <rdfs:label xml:lang="en">Affects Device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#affectsDeviceType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#affectsDeviceType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DeviceType"/>
        <rdfs:comment xml:lang="en">Associates a risk with the type of device it affects.</rdfs:comment>
        <rdfs:label xml:lang="en">Affects Device Type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#correctsIncident -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#correctsIncident">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:comment xml:lang="en">Links an FSCA to the incident that it aims to correct or mitigate.</rdfs:comment>
        <rdfs:label xml:lang="en">Corrects Incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasActionType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasActionType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ActionType"/>
        <rdfs:comment xml:lang="en">Associates an FSCA with the type of corrective action performed.</rdfs:comment>
        <rdfs:label xml:lang="en">Has Action Type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasCountry -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasCountry">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Country"/>
        <rdfs:comment xml:lang="en">Links a manufacturer to the country in which it is based or registered.</rdfs:comment>
        <rdfs:label xml:lang="en">Has Country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasDeviceType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasDeviceType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DeviceType"/>
        <rdfs:comment xml:lang="en">Associates a device with its corresponding device type classification.</rdfs:comment>
        <rdfs:label xml:lang="en">Has Device Type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasManufacturer -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasManufacturer">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Manufacturer"/>
        <rdfs:comment xml:lang="en">Links a device to the manufacturer responsible for producing it.</rdfs:comment>
        <rdfs:label xml:lang="en">Has Manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasRegulatoryFramework -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasRegulatoryFramework">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Associates a device with the regulatory framework under which it is classified or evaluated.</rdfs:comment>
        <rdfs:label xml:lang="en">Has Regulatory Framework</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasRisk -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasRisk">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Risk"/>
        <rdfs:comment xml:lang="en">Links an incident to a specific risk identified in the dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">Has Risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasRiskCategory -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasRiskCategory">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskCategory"/>
        <rdfs:comment xml:lang="en">Associates a risk with its corresponding risk category classification.</rdfs:comment>
        <rdfs:label xml:lang="en">Has Risk Category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasRiskClass -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasRiskClass">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskClass"/>
        <rdfs:comment xml:lang="en">Links a device to its risk class according to regulatory or safety criteria.</rdfs:comment>
        <rdfs:label xml:lang="en">Has Risk Class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasRiskType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasRiskType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskType"/>
        <rdfs:comment xml:lang="en">Associates a risk with the type of adverse event or failure it represents.</rdfs:comment>
        <rdfs:label xml:lang="en">Has Risk Type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#reportedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#reportedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Manufacturer"/>
        <rdfs:comment xml:lang="en">Links an incident to the manufacturer that reported it.</rdfs:comment>
        <rdfs:label xml:lang="en">Reported By</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#reportedInCountry -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#reportedInCountry">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Country"/>
        <rdfs:comment xml:lang="en">Indicates the country in which an incident was reported.</rdfs:comment>
        <rdfs:label xml:lang="en">Reported In Country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Risk_Name -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Risk_Name">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of the detected risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#action_date -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#action_date">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The date on which the field safety corrective action was initiated.</rdfs:comment>
        <rdfs:label xml:lang="en">Action Date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#authorization_number -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#authorization_number">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The regulatory authorization or registration number assigned to the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">Authorization Number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#closure_date -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#closure_date">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The date on which the FSCA was officially closed.</rdfs:comment>
        <rdfs:label xml:lang="en">Closure Date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#competent_authority -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#competent_authority">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The regulatory authority responsible for supervising the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">Competent Authority</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#contact_email -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#contact_email">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The official contact email address of the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">Contact Email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#corrective_action_taken -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#corrective_action_taken">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">A description of any corrective action taken in response to the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Corrective Action Taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#countries_affected -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#countries_affected">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A textual list of the countries affected by the field safety corrective action, as reported in the dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">Countries Affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#detection_date -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#detection_date">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The date on which the incident was detected.</rdfs:comment>
        <rdfs:label xml:lang="en">Detection Date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#device_name -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#device_name">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The commercial name of the medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#devices_affected -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#devices_affected">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">A description of the devices affected by the FSCA.</rdfs:comment>
        <rdfs:label xml:lang="en">Devices Affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#eudamed_fsca_ref -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#eudamed_fsca_ref">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The reference identifier of the FSCA in the EUDAMED database.</rdfs:comment>
        <rdfs:label xml:lang="en">EUDAMED FSCA Reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#eudamed_incident_ref -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#eudamed_incident_ref">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The reference identifier of the incident in the EUDAMED database.</rdfs:comment>
        <rdfs:label xml:lang="en">EUDAMED Incident Reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#eudamed_srn -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#eudamed_srn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The Single Registration Number assigned to the manufacturer in EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">EUDAMED SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#event_date -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#event_date">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The date on which the incident occurred.</rdfs:comment>
        <rdfs:label xml:lang="en">Event Date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#fsca_description -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#fsca_description">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A detailed description of the field safety corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA Description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#fsca_status -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#fsca_status">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The current status of the field safety corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA Status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#imdrf_code -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#imdrf_code">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The IMDRF adverse event code associated with the risk, following the IMDRF terminologies for medical device reporting.</rdfs:comment>
        <rdfs:label xml:lang="en">IMDRF Code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#incident_description -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#incident_description">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A textual description of the incident and its circumstances.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident Description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#incident_type -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#incident_type">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The classification of the incident according to the reporting system.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident Type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#intended_purpose -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#intended_purpose">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The intended medical purpose or function of the device as declared by the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">Intended Purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#is_active -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#is_active">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether the device relies on an external source of energy to function.</rdfs:comment>
        <rdfs:label xml:lang="en">Is Active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#is_implantable -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#is_implantable">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether the device is intended to be implanted in the human body.</rdfs:comment>
        <rdfs:label xml:lang="en">Is Implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#is_reusable -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#is_reusable">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether the device is intended to be reused after reprocessing.</rdfs:comment>
        <rdfs:label xml:lang="en">Is Reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#manufacturer_name -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#manufacturer_name">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The legal name of the manufacturer responsible for the device.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer Name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#outcome -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#outcome">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The clinical or operational outcome resulting from the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#patient_age -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#patient_age">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">The age of the patient involved in the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Patient Age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#patient_sex -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#patient_sex">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The sex of the patient involved in the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Patient Sex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#probability -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#probability">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The estimated likelihood of occurrence of the risk, based on the information provided in the dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">Probability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#report_date -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#report_date">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The date on which the incident was officially reported.</rdfs:comment>
        <rdfs:label xml:lang="en">Report Date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#reporting_entity -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#reporting_entity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The organization or individual who reported the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Reporting Entity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#risk_description -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#risk_description">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A textual description of the risk, summarizing its nature, context, and potential consequences as reported in the dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#scope -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#scope">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A textual description of the scope of the FSCA, including affected lots, models or time periods.</rdfs:comment>
        <rdfs:label xml:lang="en">Scope</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#severity -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#severity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The severity level associated with the risk, indicating the potential impact or harm if the risk materializes.</rdfs:comment>
        <rdfs:label xml:lang="en">Severity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#udi_di -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#udi_di">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">he Unique Device Identifier - Device Identifier assigned to the device.</rdfs:comment>
        <rdfs:label xml:lang="en">UDI-DI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ActionType -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ActionType">
        <rdfs:comment xml:lang="en">The type of corrective action taken in an FSCA, such as recall or field correction.</rdfs:comment>
        <rdfs:label xml:lang="en">Action Type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ActiveDevice -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DeviceType"/>
        <rdfs:comment xml:lang="en">A device that relies on an external source of energy to operate.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ActiveImplant -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ActiveImplant">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DeviceType"/>
        <rdfs:comment xml:lang="en">An implantable device that requires an external or internal power source to function.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Implant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ContaminationRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ContaminationRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskType"/>
        <rdfs:comment xml:lang="en">A risk caused by biological, chemical, or particulate contamination of a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Contamination Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Country -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Country">
        <rdfs:comment xml:lang="en">A country associated with a manufacturer, incident report or FSCA impact.</rdfs:comment>
        <rdfs:label xml:lang="en">Country</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#CybersecurityRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskType"/>
        <rdfs:comment xml:lang="en">A risk related to unauthorized access, data breaches, or cyberattacks affecting a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Cybersecurity Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Device -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Device">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasRiskClass"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskClass"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Manufacturer"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A medical device registered in the dataset, including its characteristics, regulatory information and intended purpose.</rdfs:comment>
        <rdfs:label xml:lang="en">Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DeviceFailure -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DeviceFailure">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskCategory"/>
        <rdfs:comment xml:lang="en">A category describing risks related to device malfunction or breakdown.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Failure</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DevicePerformance -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DevicePerformance">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskCategory"/>
        <rdfs:comment xml:lang="en">A category describing risks related to degraded or insufficient device performance.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Performance</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DeviceSafety -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DeviceSafety">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskCategory"/>
        <rdfs:comment xml:lang="en">A category describing risks that compromise the safety of the device during use.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Safety</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DeviceType -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DeviceType">
        <rdfs:comment xml:lang="en">A classification describing the functional category of a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DiagnosticError -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DiagnosticError">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskCategory"/>
        <rdfs:comment xml:lang="en">A category describing risks related to incorrect or misleading diagnostic outcomes.</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnostic Error</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DiagnosticRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskType"/>
        <rdfs:comment xml:lang="en">A risk arising from incorrect, delayed, or inaccurate diagnostic results produced by a device.</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnostic Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#FSCA">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#hasActionType"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ActionType"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A field safety corrective action issued to mitigate or prevent risks associated with a medical device already placed on the market.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#HighRiskIncident -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#HighRiskIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident"/>
        <rdfs:comment xml:lang="en">An incident which is classified with a &quot;High Risk&quot;.</rdfs:comment>
        <rdfs:label xml:lang="en">High Risk Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ImplantableActiveDevice -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ImplantableActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DeviceType"/>
        <rdfs:comment xml:lang="en">A device that is both implantable and active, typically used for life-supporting or therapeutic functions.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ImplantableDevice -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DeviceType"/>
        <rdfs:comment xml:lang="en">A device intended to be implanted in the human body for long-term use.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#InSituCorrection -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#InSituCorrection">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ActionType"/>
        <rdfs:comment xml:lang="en">A corrective action performed directly on devices already in the field without removing them from service.</rdfs:comment>
        <rdfs:label xml:lang="en">In-Situ Correction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#InVitroDiagnosticDevice -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DeviceType"/>
        <rdfs:comment xml:lang="en">A device used to examine specimens derived from the human body for diagnostic purposes.</rdfs:comment>
        <rdfs:label xml:lang="en">In Vitro Diagnostic Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Incident">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#affectsDevice"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Device"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">An event involving a medical device that resulted in or could have resulted in harm to a patient or user.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#InfectionRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#InfectionRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskType"/>
        <rdfs:comment xml:lang="en">A risk of infection associated with the use, implantation, or handling of a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Infection Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#InjuryRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#InjuryRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskType"/>
        <rdfs:comment xml:lang="en">A risk that may lead to physical injury to a patient or user.</rdfs:comment>
        <rdfs:label xml:lang="en">Injury Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#InterferenceRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#InterferenceRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskType"/>
        <rdfs:comment xml:lang="en">A risk resulting from device malfunction or unexpected failure during use.</rdfs:comment>
        <rdfs:label xml:lang="en">Interference Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#MalfunctionRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#MalfunctionRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskType"/>
        <rdfs:comment xml:lang="en">A risk resulting from device malfunction or unexpected failure during use.</rdfs:comment>
        <rdfs:label xml:lang="en">Malfunction Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Manufacturer -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Manufacturer">
        <rdfs:comment xml:lang="en">An organization responsible for producing or placing a medical device on the market.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#MaterialRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#MaterialRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskType"/>
        <rdfs:comment xml:lang="en">A risk caused by material degradation, incompatibility, or defects in device components.</rdfs:comment>
        <rdfs:label xml:lang="en">Material Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#PatientHarm -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#PatientHarm">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskCategory"/>
        <rdfs:comment xml:lang="en">A category describing risks that may cause harm or injury to a patient.</rdfs:comment>
        <rdfs:label xml:lang="en">Patient Harm</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ProductQuality -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ProductQuality">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskCategory"/>
        <rdfs:comment xml:lang="en">A category describing risks related to manufacturing defects or quality issues.</rdfs:comment>
        <rdfs:label xml:lang="en">Product Quality</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RadiationRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RadiationRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskType"/>
        <rdfs:comment xml:lang="en">A risk associated with exposure to harmful levels of radiation emitted or used by a device.</rdfs:comment>
        <rdfs:label xml:lang="en">Radiation Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Recall -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Recall">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ActionType"/>
        <rdfs:comment xml:lang="en">A corrective action involving the withdrawal of a medical device from the market or from use.</rdfs:comment>
        <rdfs:label xml:lang="en">Recall</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RegulatoryFramework -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RegulatoryFramework">
        <rdfs:comment xml:lang="en">The regulatory framework under which a device is classified, such as MDR or IVDR.</rdfs:comment>
        <rdfs:label xml:lang="en">Regulatory Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Risk -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#Risk">
        <rdfs:comment xml:lang="en">A potential hazard or adverse effect associated with the use or malfunction of a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskCategory -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskCategory">
        <rdfs:comment xml:lang="en">A category describing the nature of the risk associated with a device or incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Category</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskClass -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskClass">
        <rdfs:comment xml:lang="en">The regulatory risk class assigned to a medical device according to MDR/IVDR rules.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Class</rdfs:label>
        <rdfs:sameAs>http://dbpedia.org/resource/Medical_device#Risk_classification</rdfs:sameAs>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskType -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskType">
        <rdfs:comment xml:lang="en">A specific type of risk, such as mechanical, electrical or biological.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#SafetyAlert -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#SafetyAlert">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ActionType"/>
        <rdfs:comment xml:lang="en">A notification issued to warn users about a potential safety issue related to a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Safety Alert</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#SelfTestDevice -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#SelfTestDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#SingleUseDevice"/>
        <rdfs:comment xml:lang="en">A device intended to be used directly by patients for self-testing.</rdfs:comment>
        <rdfs:label xml:lang="en">Self-test Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#SingleUseDevice -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#SingleUseDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DeviceType"/>
        <rdfs:comment xml:lang="en">A device intended for one-time use and not suitable for reprocessing or reuse.</rdfs:comment>
        <rdfs:label xml:lang="en">Single-use Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#SoftwareRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#SoftwareRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RiskType"/>
        <rdfs:comment xml:lang="en">A risk arising from software malfunction, bugs, or incorrect algorithmic behavior in a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Software Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#UserNotice -->

    <owl:Class rdf:about="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#UserNotice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#ActionType"/>
        <rdfs:comment xml:lang="en">A communication issued to inform users about important information related to a medical device, such as updated instructions, warnings, or operational recommendations.</rdfs:comment>
        <rdfs:label xml:lang="en">User Notice</rdfs:label>
    </owl:Class>
    


