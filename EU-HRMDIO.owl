        <untitled-ontology-4:affectsDevice rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#DEV-003"/>
        <untitled-ontology-4:hasRisk rdf:resource="http://www.semanticweb.org/mawe/ontologies/2026/3/untitled-ontology-4#RSK-005"/>
