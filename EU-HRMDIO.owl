        <untitled-ontology-4:intended_purpose>Transcatheter aortic valve replacement (TAVI)</untitled-ontology-4:intended_purpose>
        <untitled-ontology-4:is_active rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</untitled-ontology-4:is_active>
